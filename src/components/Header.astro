---
// Header — minimal, sticky, dark
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-navy-950/70 border-b border-white/5">
  <div class="container-wide flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-3 group" aria-label="Lewis Cloud Innovations home">
      <div class="flex items-center">
  <img
    src="/LewisCloud-logo.svg"
    alt="Lewis Cloud Innovations"
    width="220"
    height="32"
    style="height: 32px; width: auto;"
  />
</div>
    </a>

    <nav class="flex items-center gap-2 sm:gap-4" aria-label="Primary">
      <a
        href="#services"
        class="hidden md:inline-block text-sm text-slate-300 hover:text-white transition-colors px-3 py-2"
      >
        Services
      </a>
      <a
        href="#industries"
        class="hidden md:inline-block text-sm text-slate-300 hover:text-white transition-colors px-3 py-2"
      >
        Industries
      </a>
      <a
        href="#approach"
        class="hidden md:inline-block text-sm text-slate-300 hover:text-white transition-colors px-3 py-2"
      >
        Approach
      </a>
      <a href="#contact" class="btn-primary text-xs sm:text-sm py-2 sm:py-2.5 px-3 sm:px-4">
        Contact
