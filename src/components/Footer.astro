---
const year = new Date().getFullYear();
---

<footer class="relative pt-16 pb-10 mt-12">
  <div class="section-divider absolute top-0 left-0 right-0"></div>

  <div class="container-wide">
    <div class="grid md:grid-cols-3 gap-10 mb-12">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span
            class="font-mono text-teal-400 font-bold tracking-[0.25em] text-sm"
            aria-hidden="true"
          >
            LCI
          </span>
          <span class="w-px h-4 bg-white/15"></span>
          <span class="text-white text-sm font-semibold">
            Lewis Cloud Innovations
          </span>
        </div>
        <p class="text-sm text-slate-400 leading-relaxed max-w-xs">
          AWS-first, zero-trust, compliance-aware cloud and cybersecurity
          services.
        </p>
      </div>

      <div>
        <h4
          class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-4"
        >
          Practice
        </h4>
        <ul class="space-y-2.5">
          <li>
            <a
              href="#services"
              class="text-sm text-slate-300 hover:text-teal-300 transition-colors"
              >Services</a
            >
          </li>
          <li>
            <a
              href="#industries"
              class="text-sm text-slate-300 hover:text-teal-300 transition-colors"
              >Industries</a
            >
          </li>
          <li>
            <a
              href="#approach"
              class="text-sm text-slate-300 hover:text-teal-300 transition-colors"
              >Approach</a
            >
          </li>
          <li>
            <a
              href="#contact"
              class="text-sm text-slate-300 hover:text-teal-300 transition-colors"
              >Contact</a
            >
          </li>
        </ul>
      </div>

      <div>
        <h4
          class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-4"
        >
          Legal
        </h4>
        <ul class="space-y-2.5">
          <li>
            <a
              href="/LewisCloud-privacy"
              class="text-sm text-slate-300 hover:text-teal-300 transition-colors"
              >Privacy Policy</a
            >
          </li>
          <li>
            <a
              href="/LewisCloud-terms"
              class="text-sm text-slate-300 hover:text-teal-300 transition-colors"
              >Terms of Service</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div
      class="pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-3"
    >
      <p class="text-xs text-slate-500">
        © {year} Lewis Cloud Innovations. All rights reserved.
      </p>
      <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500">
        AWS af-south-1 · Built with Astro on Cloudflare
      </p>
    </div>
  </div>
</footer>
