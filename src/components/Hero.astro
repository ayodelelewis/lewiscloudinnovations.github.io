---
// Hero — launching-soon framing, navy/teal, premium feel
---

<section class="relative pt-20 pb-24 md:pt-32 md:pb-40 overflow-hidden">
  <!-- Decorative ambient glow -->
  <div
    class="absolute inset-0 -z-10 pointer-events-none"
    aria-hidden="true"
  >
    <div
      class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[1000px] rounded-full"
      style="background: radial-gradient(circle, rgba(0,166,166,0.12) 0%, transparent 60%); filter: blur(60px);"
    >
    </div>
  </div>

  <div class="container-wide">
    <!-- Status pill -->
    <div class="reveal flex justify-center mb-8">
      <div
        class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full border border-teal-500/30 bg-teal-500/5 backdrop-blur-sm"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"
          ></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-teal-500"></span>
        </span>
        <span
          class="font-mono text-xs font-medium tracking-[0.15em] uppercase text-teal-300"
        >
          Launching Soon — Now Onboarding Select Engagements
        </span>
      </div>
    </div>

    <!-- Eyebrow -->
    <div class="reveal flex justify-center mb-6">
      <span class="eyebrow">Cloud &amp; Cybersecurity Services</span>
    </div>

    <!-- Headline -->
    <h1 class="reveal heading-1 text-center max-w-4xl mx-auto mb-6">
      Secure cloud,
      <span
        class="bg-gradient-to-r from-teal-400 via-teal-300 to-teal-500 bg-clip-text text-transparent"
      >
        engineered for the regulated.
      </span>
    </h1>

    <!-- Subhead -->
    <p
      class="reveal body-large text-center max-w-2xl mx-auto mb-10"
      style="animation-delay: 0.1s;"
    >
      Lewis Cloud Innovations builds AWS-native, zero-trust infrastructure for
      fintech, healthcare, government, and high-growth enterprises — with
      compliance baked in, not bolted on.
    </p>

    <!-- CTAs -->
    <div
      class="reveal flex flex-col sm:flex-row gap-3 justify-center items-center"
      style="animation-delay: 0.2s;"
    >
      <a href="#contact" class="btn-primary">
        Start an Engagement
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
      <a href="#services" class="btn-secondary">
        Explore Services
      </a>
    </div>

    <!-- Trust strip -->
    <div
      class="reveal mt-20 pt-10 border-t border-white/5"
      style="animation-delay: 0.3s;"
    >
      <p
        class="font-mono text-xs uppercase tracking-[0.2em] text-slate-500 text-center mb-6"
      >
        Built on
      </p>
      <div
        class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-slate-400"
      >
        <span class="font-mono text-sm font-medium">AWS af-south-1</span>
        <span class="opacity-30">•</span>
        <span class="font-mono text-sm font-medium">Zero-Trust by Default</span>
        <span class="opacity-30">•</span>
        <span class="font-mono text-sm font-medium">NIST SP 800-207</span>
        <span class="opacity-30">•</span>
        <span class="font-mono text-sm font-medium">Multi-Region DR</span>
      </div>
    </div>
  </div>
</section>
